[23bcs102@mepcolinux ex8]$cat pr1.c
#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <omp.h>

int main() {
    int n = 10000000,i;
    srand(time(NULL));

    int *a = malloc(n * sizeof(int));
    int *b = malloc(n * sizeof(int));
    int *c = malloc(n * sizeof(int));

    #pragma omp parallel for
    for (i = 0; i < n; i++) {
        a[i] = rand() % 100;
        b[i] = rand() % 100;
    }

    #pragma omp parallel for
    for (i = 0; i < n; i++) {
        c[i] = a[i] + b[i];
    }
    printf("Sample first 5 data : \n");
    for (i = 0; i < 5; i++) {
        printf("%d + %d = %d\n", a[i], b[i], c[i]);
    }

    free(a);
    free(b);
    free(c);

    return 0;
}

[23bcs102@mepcolinux ex8]$cc -fopenmp pr1.c
[23bcs102@mepcolinux ex8]$./a.out
